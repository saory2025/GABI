<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Protocolo 10</title>
<style>
body{margin:0;background:black;color:#00ffc3;font-family:monospace;display:flex;justify-content:center;align-items:center;height:100vh;overflow:hidden}
.container{text-align:center;width:90%;max-width:600px}
input,button{margin-top:10px;padding:10px;background:black;color:#00ffc3;border:1px solid #00ffc3;width:80%}
#texto::after{content:"|";animation:blink 1s infinite}
@keyframes blink{0%,50%,100%{opacity:1}25%,75%{opacity:0}}
.hint{position:fixed;font-size:10px;opacity:0.1}
.top-left{top:5px;left:5px}
.bottom-right{bottom:5px;right:5px}
.glitch{animation:glitch 0.2s}
@keyframes glitch{0%{transform:0}20%{transform:translate(-5px,3px)}40%{transform:translate(5px,-3px)}60%{transform:translate(-3px,2px)}80%{transform:translate(3px,-2px)}100%{transform:0}}
</style>
</head>
<body>

<div class="container">
<h1>PROTOCOLO 10</h1>
<p id="texto"></p>
<input id="resposta" placeholder="Digite a resposta">
<button onclick="verificar()">Enviar</button>
</div>

<div class="hint top-left">primeiras letras</div>
<div class="hint bottom-right">nem tudo está aqui</div>

<script>
const fases=[
{texto:"Eu falo sem boca, ouço sem ouvidos.",resposta:"eco"},
{texto:"Silêncio é essencial. Ignore o óbvio. Guarde. Insista. Leia. Olhe.",resposta:"sigilo"},
{texto:"1001001 1100101 1110011 1110100 1100101",resposta:"teste"},
{texto:"Veja além do que é mostrado.",resposta:"verdade"},
{texto:"Você ainda acha que isso é só um site?",resposta:"fragmento"},
{texto:".-.. .. ...- .-. .",resposta:"livre"},
{texto:"5 máquinas fazem 5 peças em 5 minutos.",resposta:"5"},
{texto:"Onde tudo começa?",resposta:"origem"},
{texto:"XUFRJ",resposta:"mente"},
{texto:"Use tudo que viu.",resposta:"confie"}
];

let fase=0;
let erros=0;
let tempo=Date.now();

function digitar(txt){
 let el=document.getElementById("texto");
 el.innerHTML="";
 let i=0;
 function loop(){
  if(i<txt.length){el.innerHTML+=txt[i];i++;setTimeout(loop,25)}
 }
 loop();
}

function carregar(){digitar(fases[fase].texto);tempo=Date.now();}

function verificar(){
 let val=document.getElementById("resposta").value.toLowerCase();
 if(val===fases[fase].resposta){
  fase++;
  erros=0;
  document.getElementById("resposta").value="";
  if(fase>=fases.length){final();return}
  carregar();
 }else{
  erros++;
  if(erros>3){document.body.classList.add("glitch");document.getElementById("texto").innerText="eu estou observando você"}
  else{document.getElementById("texto").innerText="errado..."}
 }
}

setInterval(()=>{
 let t=(Date.now()-tempo)/1000;
 if(t>30){document.getElementById("texto").innerText="você está demorando..."}
},5000);

function final(){
 document.body.innerHTML="<h1 style='text-align:center;color:#00ffc3'>Você finalmente conseguiu.<br><br>Envie um áudio dizendo:<br><br><i>eu sou uma grande vírgula da porra</i></h1>";
}

carregar();
</script>

</body>
</html>
